# --- Required ---
# Pflichtwert: zufälliger Schlüssel für die JWT-Signatur.
# Erzeugen: openssl rand -hex 32
JWT_SECRET=changeme-please-run-openssl-rand-hex-32

# --- Optional ---
# Port, auf dem der Server lauscht. Default: 3000
PORT=3000

# Pfad zur SQLite-Datei (wird automatisch angelegt). Default: ./data/app.db
DB_PATH=./data/app.db

# Verzeichnis mit dem gebauten Frontend (Vite output). Default: ../dist
FRONTEND_DIST=../dist

# Optional: Startwerte für Google OAuth. Können auch nachträglich
# im Admin-Bereich der App eingetragen werden.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=https://meine-domain.de/api/auth/google/callback
